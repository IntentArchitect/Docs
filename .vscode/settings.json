// Place your settings in this file to overwrite default and user settings.
{
    "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/_site": true,
    "**/.cache": true
  },
  "github.copilot.chat.instructionsFilesLocations": ["AGENTS.md"],
  "github.copilot.chat.useAgentsMdFile": true,
  "markdownlint.config": {
    "MD028": false,
    "MD025": {
      "front_matter_title": ""
    },
    "MD060": {
      "aligned_delimiter": false
    }
  },
  "cSpell.words": [
    "appsettings",
    "Blazor",
    "configurator",
    "cursorrules",
    "EACCESS",
    "frontmatter",
    "idempotently",
    "launchsettings",
    "Mapperly",
    "nameof",
    "namespaceanddescendants",
    "Ollama",
    "Qube",
    "Rdbms",
    "sdlc",
    "Serilog",
    "softwarefactory",
    "Structs",
    "Swashbuckle",
    "Triggerable",
    "typeref",
    "unconfigured"
  ]
}